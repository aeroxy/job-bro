{
  "name": "job-bro",
  "description": "AI-powered LinkedIn job posting analyzer Chrome extension",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "author": "Aero Wang <aero.windwalker@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeroxy/job-bro.git"
  },
  "keywords": [
    "chrome-extension",
    "linkedin",
    "job-search",
    "ai",
    "analyzer"
  ],
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "package": "bun run build && cd .output/chrome-mv3 && zip -r ../job-bro.zip . && cd ../.. && mv .output/job-bro.zip .output/job-bro.crx",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@radix-ui/react-collapsible": "^1.1.7",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tailwindcss/vite": "^4.1.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.1",
    "@wxt-dev/module-react": "^1.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "marked": "^17.0.6"
  }
}
